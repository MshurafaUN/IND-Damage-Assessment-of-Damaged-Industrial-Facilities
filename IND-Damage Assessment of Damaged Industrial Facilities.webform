ta-type-xml=\"select1\" id=\"id34\">\n      <i class=\"webform-svg-icon radio\"><svg width=\"24\" height=\"24\" xmlns=\"http://www.w3.org/2000/svg\">\n  <g>\n    <path class=\"background\" fill=\"#000\" fill-rule=\"evenodd\" d=\"M12 0c6.627 0 12 5.373 12 12s-5.373 12-12 12S0 18.627 0 12 5.373 0 12 0zm0 3a9 9 0 100 18 9 9 0 000-18z\"></path>\n    <path class=\"checkmark\" fill=\"#000\" fill-rule=\"evenodd\" d=\"M12 6a6 6 0 110 12 6 6 0 010-12z\"></path>\n  </g>\n</svg></i>\n    <span lang=\"\" class=\"option-label active\" id=\"id35\">NEW</span></label></div></fieldset></fieldset><fieldset class=\"question simple-select or-appearance-hidden type-singleChoice\"><fieldset><legend><span lang=\"\" class=\"question-label active\" id=\"id36\">هل هو في المناطق الأمنة</span>\n                    </legend><div class=\"option-wrapper\"><label class=\"\"><input type=\"radio\" name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/intro/isRedZone\" data-name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/intro/isRedZone\" value=\"1\" data-type-xml=\"select1\" id=\"id37\">\n      <i class=\"webform-svg-icon radio\"><svg width=\"24\" height=\"24\" xmlns=\"http://www.w3.org/2000/svg\">\n  <g>\n    <path class=\"background\" fill=\"#000\" fill-rule=\"evenodd\" d=\"M12 0c6.627 0 12 5.373 12 12s-5.373 12-12 12S0 18.627 0 12 5.373 0 12 0zm0 3a9 9 0 100 18 9 9 0 000-18z\"></path>\n    <path class=\"checkmark\" fill=\"#000\" fill-rule=\"evenodd\" d=\"M12 6a6 6 0 110 12 6 6 0 010-12z\"></path>\n  </g>\n</svg></i>\n    <span lang=\"\" class=\"option-label active\" id=\"id38\">نعم</span></label><label class=\"\"><input type=\"radio\" name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/intro/isRedZone\" data-name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/intro/isRedZone\" value=\"2\" data-type-xml=\"select1\" id=\"id39\">\n      <i class=\"webform-svg-icon radio\"><svg width=\"24\" height=\"24\" xmlns=\"http://www.w3.org/2000/svg\">\n  <g>\n    <path class=\"background\" fill=\"#000\" fill-rule=\"evenodd\" d=\"M12 0c6.627 0 12 5.373 12 12s-5.373 12-12 12S0 18.627 0 12 5.373 0 12 0zm0 3a9 9 0 100 18 9 9 0 000-18z\"></path>\n    <path class=\"checkmark\" fill=\"#000\" fill-rule=\"evenodd\" d=\"M12 6a6 6 0 110 12 6 6 0 010-12z\"></path>\n  </g>\n</svg></i>\n    <span lang=\"\" class=\"option-label active\" id=\"id40\">لا</span></label></div></fieldset></fieldset><label class=\"question non-select or-appearance-hidden\"><div class=\"label-container\"><span lang=\"\" class=\"question-label active\" id=\"id41\">logo</span></div><span lang=\"\" class=\"or-hint active\" id=\"id42\">logo</span><input type=\"text\" name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/intro/logo\" data-type-xml=\"string\" readonly=\"\" id=\"id43\"></label><label class=\"question non-select \"><div class=\"label-container\"><span lang=\"\" class=\"question-label active\" id=\"id44\">هذا الاستبيان مخصص للتبليغ عن أضرار المنشآت الصناعية والتي تعمل ضمن نطاق القطاع الصناعي وضمن أحد مجالات الصناعة المصنفة في الطلب سواء أعضاء أو غير أعضاء</span></div><input type=\"text\" name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/intro/note01\" data-type-xml=\"string\" readonly=\"\" id=\"id45\"></label><label class=\"question non-select or-appearance-multiline\"><div class=\"label-container\"><span lang=\"\" class=\"question-label active\" id=\"id46\">ملاحظات الإشراف</span></div><textarea name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/intro/Supervision_Notes\" data-type-xml=\"string\" readonly=\"\" id=\"id47\"></textarea></label><label class=\"question non-select or-appearance-hidden\"><div class=\"label-container\"><span lang=\"\" class=\"question-label active\" id=\"id48\">رقم الطب في الكوبو</span></div><input type=\"text\" name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/intro/kobo_id_number\" data-type-xml=\"string\" id=\"id49\"></label><label class=\"question non-select or-appearance-hidden\"><div class=\"label-container\"><span lang=\"\" class=\"question-label active\" id=\"id50\">تاريخ الطلب على الكوبو</span></div><input type=\"text\" name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/intro/kobo_Date\" data-type-xml=\"string\" id=\"id51\"></label>\n            </section><!--end of group --><section class=\"or-group or-appearance-field-list\" name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information\"><h4><span lang=\"\" class=\"question-label active\" id=\"id52\">أولا: البيانات العامة</span></h4><section class=\"or-group \" name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Applicant_Information\"><h4><span lang=\"\" class=\"question-label active\" id=\"id53\">بيانات مقدم الطلب</span></h4><label class=\"question non-select \"><div class=\"label-container\"><span lang=\"\" class=\"question-label active\" id=\"id54\">سيتم اعتبار مقدم الطلب بمثابة مفوض عن المنشأة الصناعية وسيتم التواصل معه لاحقا ضمن عملية المسح والتقييم</span></div><span lang=\"\" class=\"or-hint active\" id=\"id55\">سيتم اعتبار مقدم الطلب بمثابة مفوض عن المنشأة الصناعية وسيتم التواصل معه لاحقا ضمن عملية المسح والتقييم</span><input type=\"text\" name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Applicant_Information/note03\" data-type-xml=\"string\" readonly=\"\" id=\"id56\"></label><label class=\"question non-select \"><div class=\"label-container\"><span lang=\"\" class=\"question-label active\" id=\"id57\">1.1 اسم مقدم الطلب</span><span class=\"required\" id=\"id58\">*</span></div><input type=\"text\" name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Applicant_Information/Q1_1_applicant_name\" data-required=\"true()\" data-type-xml=\"string\" id=\"id59\"><span class=\"or-required-msg active\" lang=\"\" id=\"id59\" data-i18n=\"constraint.required\">This field is required</span></label><fieldset class=\"question simple-select  type-singleChoice\"><fieldset><legend><span lang=\"\" class=\"question-label active\" id=\"id60\">أُقرّ أنا مقدّم هذا الطلب، وبكامل إرادتي وأهليتي القانونية، بأنني قد اطّلعت على المعلومات الخاصة بمشروع حصر وتقييم الأضرار الصناعية، وأدرك طبيعة هذا المشروع وأهدافه وآليات تنفيذـه. وأوافق على المشاركة فيه وفقاً للشروط والأحكام المعتمدة، بما في ذلك السماح بجمع ومعالجة واستخدام البيانات المتعلقة بالمنشأة الصناعية العائدة لي، وإجراء الزيارات الميدانية اللازمة للتحقق من صحة المعلومات المقدّمة، على أن يُقتصر استخدام هذه البيانات على أغراض المشروع فقط وضمن الأطر القانونية المعمول بها.</span><span class=\"required\" id=\"id61\">*</span>\n                    </legend><div class=\"option-wrapper\"><label class=\"\"><input type=\"radio\" name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Applicant_Information/note02\" data-name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Applicant_Information/note02\" value=\"1\" data-required=\"true()\" data-type-xml=\"select1\" id=\"id62\">\n      <i class=\"webform-svg-icon radio\"><svg width=\"24\" height=\"24\" xmlns=\"http://www.w3.org/2000/svg\">\n  <g>\n    <path class=\"background\" fill=\"#000\" fill-rule=\"evenodd\" d=\"M12 0c6.627 0 12 5.373 12 12s-5.373 12-12 12S0 18.627 0 12 5.373 0 12 0zm0 3a9 9 0 100 18 9 9 0 000-18z\"></path>\n    <path class=\"checkmark\" fill=\"#000\" fill-rule=\"evenodd\" d=\"M12 6a6 6 0 110 12 6 6 0 010-12z\"></path>\n  </g>\n</svg></i>\n    <span lang=\"\" class=\"option-label active\" id=\"id63\">أقر على ذلك</span></label></div></fieldset><span class=\"or-required-msg active\" lang=\"\" id=\"id64\" data-i18n=\"constraint.required\">This field is required</span></fieldset><fieldset class=\"question simple-select  type-singleChoice\"><fieldset><legend><span lang=\"\" class=\"question-label active\" id=\"id65\">1.2 جنس مقدم الطلب</span><span class=\"required\" id=\"id66\">*</span>\n                    </legend><div class=\"option-wrapper\"><label class=\"\"><input type=\"radio\" name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Applicant_Information/Q1_2_Applicant_Gender\" data-name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Applicant_Information/Q1_2_Applicant_Gender\" value=\"1\" data-required=\"true()\" data-type-xml=\"select1\" id=\"id67\">\n      <i class=\"webform-svg-icon radio\"><svg width=\"24\" height=\"24\" xmlns=\"http://www.w3.org/2000/svg\">\n  <g>\n    <path class=\"background\" fill=\"#000\" fill-rule=\"evenodd\" d=\"M12 0c6.627 0 12 5.373 12 12s-5.373 12-12 12S0 18.627 0 12 5.373 0 12 0zm0 3a9 9 0 100 18 9 9 0 000-18z\"></path>\n    <path class=\"checkmark\" fill=\"#000\" fill-rule=\"evenodd\" d=\"M12 6a6 6 0 110 12 6 6 0 010-12z\"></path>\n  </g>\n</svg></i>\n    <span lang=\"\" class=\"option-label active\" id=\"id68\">ذكر</span></label><label class=\"\"><input type=\"radio\" name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Applicant_Information/Q1_2_Applicant_Gender\" data-name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Applicant_Information/Q1_2_Applicant_Gender\" value=\"2\" data-required=\"true()\" data-type-xml=\"select1\" id=\"id69\">\n      <i class=\"webform-svg-icon radio\"><svg width=\"24\" height=\"24\" xmlns=\"http://www.w3.org/2000/svg\">\n  <g>\n    <path class=\"background\" fill=\"#000\" fill-rule=\"evenodd\" d=\"M12 0c6.627 0 12 5.373 12 12s-5.373 12-12 12S0 18.627 0 12 5.373 0 12 0zm0 3a9 9 0 100 18 9 9 0 000-18z\"></path>\n    <path class=\"checkmark\" fill=\"#000\" fill-rule=\"evenodd\" d=\"M12 6a6 6 0 110 12 6 6 0 010-12z\"></path>\n  </g>\n</svg></i>\n    <span lang=\"\" class=\"option-label active\" id=\"id70\">أنثى</span></label></div></fieldset><span class=\"or-required-msg active\" lang=\"\" id=\"id71\" data-i18n=\"constraint.required\">This field is required</span></fieldset><label class=\"question non-select or-appearance-numbers\"><div class=\"label-container\"><span lang=\"\" class=\"question-label active\" id=\"id72\">1.3 رقم الهوية</span><span class=\"required\" id=\"id73\">*</span></div><span lang=\"\" class=\"or-hint active\" id=\"id74\">رقم هوية مقدم الطلب</span><input type=\"tel\" name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Applicant_Information/Q1_3_ID_Number\" data-required=\"true()\" data-constraint=\"regex(., '^[1-9][0-9]{8}$')\" data-type-xml=\"string\" id=\"id75\"><span lang=\"\" class=\"or-constraint-msg active\" id=\"id76\">رقم الهوية غير صحيح. يجب أن يتكون من 9 أرقام وألا يبدأ بـ 0.</span><span class=\"or-required-msg active\" lang=\"\" id=\"id75\" data-i18n=\"constraint.required\">This field is required</span></label><fieldset class=\"question simple-select  type-singleChoice\"><fieldset><legend><span lang=\"\" class=\"question-label active\" id=\"id77\">1.4 الصفة في المنشأة</span><span class=\"required\" id=\"id78\">*</span><span lang=\"\" class=\"or-hint active\" id=\"id79\">صفة مقدم الطلب في المنشأة</span>\n                    </legend><div class=\"option-wrapper\"><label class=\"\"><input type=\"radio\" name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Applicant_Information/Q1_4_Applicant_Role_In_Facility\" data-name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Applicant_Information/Q1_4_Applicant_Role_In_Facility\" value=\"1\" data-required=\"true()\" data-type-xml=\"select1\" id=\"id80\">\n      <i class=\"webform-svg-icon radio\"><svg width=\"24\" height=\"24\" xmlns=\"http://www.w3.org/2000/svg\">\n  <g>\n    <path class=\"background\" fill=\"#000\" fill-rule=\"evenodd\" d=\"M12 0c6.627 0 12 5.373 12 12s-5.373 12-12 12S0 18.627 0 12 5.373 0 12 0zm0 3a9 9 0 100 18 9 9 0 000-18z\"></path>\n    <path class=\"checkmark\" fill=\"#000\" fill-rule=\"evenodd\" d=\"M12 6a6 6 0 110 12 6 6 0 010-12z\"></path>\n  </g>\n</svg></i>\n    <span lang=\"\" class=\"option-label active\" id=\"id81\">المالك