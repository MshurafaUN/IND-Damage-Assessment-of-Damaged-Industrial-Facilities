            "id": "/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Applicant_Information",
            "label": "بيانات مقدم الطلب",
            "name": "Applicant_Information",
            "questions": [
              {
                "description": null,
                "fieldName": "note03",
                "fieldType": "esriFieldTypeString",
                "id": "/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Applicant_Information/note03",
                "isRequired": false,
                "label": "سيتم اعتبار مقدم الطلب بمثابة مفوض عن المنشأة الصناعية وسيتم التواصل معه لاحقا ضمن عملية المسح والتقييم",
                "name": "note03",
                "readOnly": {
                  "expression": "true()",
                  "type": "xform"
                },
                "type": "esriQuestionTypeText"
              },
              {
                "description": null,
                "fieldName": "Q1_1_applicant_name",
                "fieldType": "esriFieldTypeString",
                "id": "/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Applicant_Information/Q1_1_applicant_name",
                "isRequired": true,
                "label": "1.1 اسم مقدم الطلب",
                "name": "Q1_1_applicant_name",
                "readOnly": {
                  "expression": "( /IND_Damage_Assessment_of_Damaged_Industrial_Facilities/intro/final_source  = 1 or  /IND_Damage_Assessment_of_Damaged_Industrial_Facilities/intro/final_source  = 4) and string-length(today()) > 0",
                  "type": "xform"
                },
                "type": "esriQuestionTypeText"
              },
              {
                "appearance": {
                  "layout": [
                    "vertical"
                  ]
                },
                "choices": {
                  "items": [
                    {
                      "label": "أقر على ذلك",
                      "value": "1"
                    }
                  ],
                  "other": {
                    "fieldName": "note02_other",
                    "isEnabled": false,
                    "label": null,
                    "name": "note02_other",
                    "value": "other"
                  }
                },
                "choicesOrder": {
                  "type": "default"
                },
                "description": null,
                "fieldName": "note02",
                "fieldType": "esriFieldTypeString",
                "id": "/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Applicant_Information/note02",
                "isRequired": true,
                "label": "أُقرّ أنا مقدّم هذا الطلب، وبكامل إرادتي وأهليتي القانونية، بأنني قد اطّلعت على المعلومات الخاصة بمشروع حصر وتقييم الأضرار الصناعية، وأدرك طبيعة هذا المشروع وأهدافه وآليات تنفيذـه. وأوافق على المشاركة فيه وفقاً للشروط والأحكام المعتمدة، بما في ذلك السماح بجمع ومعالجة واستخدام البيانات المتعلقة بالمنشأة الصناعية العائدة لي، وإجراء الزيارات الميدانية اللازمة للتحقق من صحة المعلومات المقدّمة، على أن يُقتصر استخدام هذه البيانات على أغراض المشروع فقط وضمن الأطر القانونية المعمول بها.",
                "name": "note02",
                "type": "esriQuestionTypeSingleChoice"
              },
              {
                "appearance": {
                  "layout": [
                    "vertical"
                  ]
                },
                "choices": {
                  "items": [
                    {
                      "label": "ذكر",
                      "value": "1"
                    },
                    {
                      "label": "أنثى",
                      "value": "2"
                    }
                  ],
