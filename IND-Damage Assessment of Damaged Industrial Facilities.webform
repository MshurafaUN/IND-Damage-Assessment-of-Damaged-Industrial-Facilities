Damages_Facilities_Components/Location_Identification/Q3_14_Site_Photos_Damage/note04\" data-type-xml=\"string\" readonly=\"\" id=\"id1377\"></label><fieldset class=\"question simple-select  type-singleChoice\"><fieldset><legend><span lang=\"\" class=\"question-label active\" id=\"id1378\">اختر وقت الصورة</span>\n                    </legend><div class=\"option-wrapper\"><label class=\"\"><input type=\"radio\" name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/Damages_Facilities_Components/Location_Identification/Q3_14_Site_Photos_Damage/Q3_site_photos\" data-name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/Damages_Facilities_Components/Location_Identification/Q3_14_Site_Photos_Damage/Q3_site_photos\" value=\"1\" data-type-xml=\"select1\" id=\"id1379\">\n      <i class=\"webform-svg-icon radio\"><svg width=\"24\" height=\"24\" xmlns=\"http://www.w3.org/2000/svg\">\n  <g>\n    <path class=\"background\" fill=\"#000\" fill-rule=\"evenodd\" d=\"M12 0c6.627 0 12 5.373 12 12s-5.373 12-12 12S0 18.627 0 12 5.373 0 12 0zm0 3a9 9 0 100 18 9 9 0 000-18z\"></path>\n    <path class=\"checkmark\" fill=\"#000\" fill-rule=\"evenodd\" d=\"M12 6a6 6 0 110 12 6 6 0 010-12z\"></path>\n  </g>\n</svg></i>\n    <span lang=\"\" class=\"option-label active\" id=\"id1380\">صورة الموقع قبل الضرر</span></label><label class=\"\"><input type=\"radio\" name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/Damages_Facilities_Components/Location_Identification/Q3_14_Site_Photos_Damage/Q3_site_photos\" data-name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/Damages_Facilities_Components/Location_Identification/Q3_14_Site_Photos_Damage/Q3_site_photos\" value=\"2\" data-type-xml=\"select1\" id=\"id1381\">\n      <i class=\"webform-svg-icon radio\"><svg width=\"24\" height=\"24\" xmlns=\"http://www.w3.org/2000/svg\">\n  <g>\n    <path class=\"background\" fill=\"#000\" fill-rule=\"evenodd\" d=\"M12 0c6.627 0 12 5.373 12 12s-5.373 12-12 12S0 18.627 0 12 5.373 0 12 0zm0 3a9 9 0 100 18 9 9 0 000-18z\"></path>\n    <path class=\"checkmark\" fill=\"#000\" fill-rule=\"evenodd\" d=\"M12 6a6 6 0 110 12 6 6 0 010-12z\"></path>\n  </g>\n</svg></i>\n    <span lang=\"\" class=\"option-label active\" id=\"id1382\">صورة الموقع بعد الضرر</span></label></div></fieldset></fieldset><label class=\"question non-select or-appearance-\"><div class=\"label-container\"><span lang=\"\" class=\"question-label active\" id=\"id1383\">يرجى رفع صور واضحة حال توافرها.</span></div><input type=\"file\" name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/Damages_Facilities_Components/Location_Identification/Q3_14_Site_Photos_Damage/Q3_14_1_Sites_photos_befor_damged\" data-type-xml=\"binary\" accept=\"application/*\" id=\"id1384\"></label><label class=\"question non-select or-appearance-hidden\"><div class=\"label-container\"><span lang=\"\" class=\"question-label active\" id=\"id1385\">يرجى رفع صور واضحة بعد حدوث الضرر</span></div><span lang=\"\" class=\"or-hint active\" id=\"id1386\">التقط صورة للأضرار التي لحقت بالمبنى أو أرفق صورة للأضرار محفوظة إلكترونياً. يرجى ملاحظة أن الأضرار تشمل جميع الأضرار المادية التي تصيب المبنى، مثل انهيار الهيكل بشكل كامل أو جزئي، أو وجود شقوق أو فجوات في أي جزء من أجزاء المبنى بما في ذلك الجدران، السقف، السقف الداخلي، الأرضيات، الأساسات والمرافق، بالإضافة إلى الأصول والمنتجات .</span><input type=\"file\" name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/Damages_Facilities_Components/Location_Identification/Q3_14_Site_Photos_Damage/Q3_14_2_Sites_photos_afrer_damged\" data-type-xml=\"binary\" accept=\"application/*\" id=\"id1387\"></label>\n            </section><div class=\"or-repeat-info\" data-name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/Damages_Facilities_Components/Location_Identification/Q3_14_Site_Photos_Damage\"></div>\n            </section><!--end of group --><section class=\"or-group \" name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/Damages_Facilities_Components/Location_Identification/Q3_16_Production_Equipment_and_Machines\"><h4><span lang=\"\" class=\"question-label active\" id=\"id1388\">3.16 المعدات والماكينات المستعملة في الانتاج</span></h4><section class=\"or-repeat \" name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/Damages_Facilities_Components/Location_Identification/Q3_16_Production_Equipment_and_Machines\"><label class=\"question non-select \"><div class=\"label-container\"><span lang=\"\" class=\"question-label active\" id=\"id1389\">هذا البند يشمل جميع أنواع المعدات والماكينات المستخدمة في عملية الإنتاج، بما في ذلك المعدات الرئيسية المساهمة بشكل مباشر في تنفيذ الأنشطة الإنتاجية</span></div><input type=\"text\" name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/Damages_Facilities_Components/Location_Identification/Q3_16_Production_Equipment_and_Machines/note06\" data-type-xml=\"string\" readonly=\"\" id=\"id1390\"></label><label class=\"question non-select \"><div class=\"label-container\"><span lang=\"\" class=\"question-label active\" id=\"id1391\">(في حال اضافة أكثر من خط انتاج قم بالضغط على اشارة (+) بالأعلى)</span></div><input type=\"text\" name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/Damages_Facilities_Components/Location_Identification/Q3_16_Production_Equipment_and_Machines/note07\" data-type-xml=\"string\" readonly=\"\" id=\"id1392\"></label><label class=\"question non-select \"><div class=\"label-container\"><span lang=\"\" class=\"question-label active\" id=\"id1393\">3.16.1 اسم خط الإنتاج</span><span class=\"required\" id=\"id1394\">*</span></div><input type=\"text\" name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/Damages_Facilities_Components/Location_Identification/Q3_16_Production_Equipment_and_Machines/Q3_16_1_production_line_name\" data-required=\" /IND_Damage_Assessment_of_Damaged_Industrial_Facilities/Damages_Facilities_Components/Location_Identification/IS_Current_Location ='1' and  /IND_Damage_Assessment_of_Damaged_Indus