plicant_Information/Q1_8_survey_status  = '2'\" data-relevant=\" /IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Establishment_Information/Q1_8_License_Type  = '9'\" data-type-xml=\"string\" id=\"id142\"><span class=\"or-required-msg active\" lang=\"\" id=\"id142\" data-i18n=\"constraint.required\">This field is required</span></label><label class=\"question or-branch pre-init non-select or-appearance-numbers\"><div class=\"label-container\"><span lang=\"\" class=\"question-label active\" id=\"id143\">1.9 رقم المشتغل المرخص</span><span class=\"required\" id=\"id144\">*</span></div><span lang=\"\" class=\"or-hint active\" id=\"id145\">في حالة نوع ترخيص المنشأة شركة (هذا يشمل جميع أنواع الشركات المسجلة في القانون)، أدخل رقم المشتغل المرخص هنا.</span><input type=\"tel\" name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Establishment_Information/Q1_9_Licensed_Worker_Number\" data-required=\" /IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Applicant_Information/Q1_8_survey_status  = '2'\" data-constraint=\"regex(., '^[1-9][0-9]{8}$')\" data-relevant=\" /IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Establishment_Information/Q1_8_License_Type  = '1' or  /IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Establishment_Information/Q1_8_License_Type  = '2' or  /IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Establishment_Information/Q1_8_License_Type  = '3' or  /IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Establishment_Information/Q1_8_License_Type  = '4' or  /IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Establishment_Information/Q1_8_License_Type  = '5'\" data-type-xml=\"string\" id=\"id146\"><span lang=\"\" class=\"or-constraint-msg active\" id=\"id147\">رقم المشتغل المرخص غير صحيح. يجب أن يتكون من 9 أرقام وألا يبدأ بـ 0.</span><span class=\"or-required-msg active\" lang=\"\" id=\"id146\" data-i18n=\"constraint.required\">This field is required</span></label><label class=\"question or-branch pre-init non-select or-appearance-numbers\"><div class=\"label-container\"><span lang=\"\" class=\"question-label active\" id=\"id148\">1.10 رقم الهوية</span><span class=\"required\" id=\"id149\">*</span></div><span lang=\"\" class=\"or-hint active\" id=\"id150\">في حالة نوع ترخيص المنشأة سجل فردي، جمعية تعاونية، ريادي أعمل، أخرى، أدخل رقم هوية مالك المنشأة.</span><input type=\"tel\" name=\"/IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Establishment_Information/Q1_10_ID_Number\" data-required=\" /IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Applicant_Information/Q1_8_survey_status  = '2'\" data-constraint=\"regex(., '^[1-9][0-9]{8}$')\" data-relevant=\" /IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Establishment_Information/Q1_8_License_Type  = '6' or  /IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Establishment_Information/Q1_8_License_Type  = '7' or  /IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Establishment_Information/Q1_8_License_Type  = '8' or  /IND_Damage_Assessment_of_Damaged_Industrial_Facilities/General_Information/Establishment_Information/Q1_8_License_Type  = '9'\" data-type-xml=\"string\" id=\"id151\"><span lang=\"\" class=\"or-constraint-msg active\" id=\"id152\">رقم المشتغل المرخص غير صحيح. يجب أن يتكون من 9 أرقام وألا يبدأ بـ 0.</span><span class=\"or-required-msg active\" lang=\"\" id=\"id151\" data-i18n=\"constraint.required\">This field is required</span></label><fieldset class=\"question simple-select  type-singleChoice\"><fieldset><legend><span lang=\"\" class=\"question-label active\" id=\"id153\">1.11 هل المنشأة مرخّصة وحاصلة على الرخصة الصناعية الصادرة من وزارة الاقتصاد الوطني؟</span><span class=\"required\" id=\"id154\">*</span>\n                 